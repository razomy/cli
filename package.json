{
  "name": "@razomy/cli",
  "description": "A new CLI generated with oclif",
  "version": "0.0.0-alpha.4",
  "author": "Yevhenii Kamenskyi",
  "bin": {
    "razomy": "bin/run.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": "https://github.com/razomy/cli/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@oclif/core": "^4.10.5",
    "@oclif/plugin-autocomplete": "^3.2.45",
    "@oclif/plugin-help": "^6.2.44",
    "@oclif/plugin-plugins": "^5.4.60",
    "extract-zip": "^2.0.1",
    "npm": "^11.12.1",
    "tar": "^7.5.13",
    "@razomy/run": "^0.0.1-alpha.2",
    "@razomy/exceptions": "^0.0.1-alpha.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4.1.18",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/tar": "^7.0.87",
    "chai": "^6.2.2",
    "eslint": "^10.2.0",
    "eslint-config-oclif": "^6.0.157",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.3.0",
    "oclif": "^4.23.0",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/razomy/cli",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "razomy",
    "dirname": "razomy",
    "commands": "./dist/commands",
    "binAliases": [
      "r"
    ],
    "plugins": [],
    "targets": [
      "darwin-x64",
      "darwin-arm64",
      "linux-x64",
      "linux-arm64",
      "win32-x64"
    ],
    "topicSeparator": " ",
    "topics": {
      "io": {
        "description": "Run npm packages functions"
      },
      "di": {
        "description": "Run DI agent to execute commands"
      },
      "cli": {
        "description": "Install npm packages in different workspaces with different runtimes"
      }
    }
  },
  "repository": {
    "directory": "",
    "type": "git",
    "url": "git+https://github.com/razomy/cli.git"
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
