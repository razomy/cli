{
  "name": "@razomy/cli",
  "description": "A new CLI generated with oclif",
  "version": "0.0.0-alpha.2",
  "author": "Yevhenii Kamenskyi",
  "bin": {
    "razomy": "./bin/run.js",
    "rr": "bin/r-run.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": "https://github.com/razomy/cli/issues",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.40",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5.4.58"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/razomy/cli",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "razomy",
    "dirname": "razomy",
    "commands": "./dist/commands",
    "binAliases": [
      "rr"
    ],
    "plugins": [],
    "targets": [
      "darwin-x64",
      "darwin-arm64",
      "linux-x64",
      "linux-arm",
      "win32-x64"
    ],
    "topicSeparator": " ",
    "topics": {
      "run": {
        "description": "Run npm packages commands"
      },
      "cli": {
        "description": "Install npm packages"
      }
    }
  },
  "repository": {
    "directory": "",
    "type": "git",
    "url": "git+https://github.com/razomy/cli.git"
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
